{
    "name": "lightweight-php-framework/core",
    "description": "轻量级高性能 PHP 框架，支持 Swoole 协程",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Framework Team",
            "email": "dev@example.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-json": "*",
        "psr/container": "^2.0",
        "psr/log": "^2.0 || ^3.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-swoole": "Required for high-concurrency coroutine mode (>=5.0)",
        "ext-redis": "Required for Redis cache driver"
    },
    "autoload": {
        "psr-4": {
            "Framework\\": "src/",
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
