# 应用配置
APP_ENV=development
APP_DEBUG=true

# 路由缓存（生产环境建议启用）
ROUTE_CACHE_ENABLED=false
ROUTE_CACHE_DIR=storage/cache

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=framework_test
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4

# 数据库连接池
DB_POOL_MAX=10
DB_POOL_TIMEOUT=3.0

# Redis 配置（可选）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# Swoole 配置
SWOOLE_HOST=0.0.0.0
SWOOLE_PORT=9501
SWOOLE_WORKERS=4
